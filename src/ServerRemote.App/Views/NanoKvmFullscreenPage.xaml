<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ServerRemote.App.Views.NanoKvmFullscreenPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:ServerRemote.App.ViewModels"
    xmlns:comp="clr-namespace:ServerRemote.App.Components"
    x:DataType="vm:NanoKvmViewModel"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    BackgroundColor="Black"
    Title="NanoKVM Fullscreen">

    <Grid BackgroundColor="Black">
        <!-- Hardware H.264 decoder (native handler per platform), flicker-free. -->
        <comp:KvmVideoView Source="{Binding Stream}" />

        <ActivityIndicator IsRunning="{Binding IsConnecting}"
                           IsVisible="{Binding IsConnecting}"
                           HorizontalOptions="Center" VerticalOptions="Center" />

        <!-- Input overlay: absolute mapping or touchpad mode (RelativeMode). -->
        <comp:KvmInputSurface Hid="{Binding Hid}"
                              IsActive="{Binding InputConnected}"
                              AspectRatio="{Binding VideoAspect}"
                              RelativeMode="{Binding RelativeMouseMode}" />

        <!-- Semi-transparent on-screen keyboard overlay at the bottom — does not cover the live image. -->
        <comp:OnScreenKeyboard ViewModel="{Binding .}"
                               IsVisible="{Binding KeyboardVisible}"
                               HorizontalOptions="Fill" VerticalOptions="End"
                               Margin="0,0,0,8" />

        <!-- Overlay control bar at top left: keyboard + mode toggle. -->
        <HorizontalStackLayout HorizontalOptions="Start" VerticalOptions="Start"
                               Margin="16" Spacing="8">
            <Button Text="⌨" Clicked="OnKeyboardToggle"
                    Style="{StaticResource NeutralButton}" Opacity="0.85" />
            <HorizontalStackLayout Spacing="6" VerticalOptions="Center" Padding="8,0">
                <Switch IsToggled="{Binding RelativeMouseMode}" VerticalOptions="Center" />
                <Label Text="Touchpad" TextColor="White" VerticalOptions="Center" />
            </HorizontalStackLayout>
        </HorizontalStackLayout>

        <!-- Close button at top right, semi-transparent over the image. -->
        <Button Text="✕ Close"
                Command="{Binding CloseFullscreenCommand}"
                Style="{StaticResource NeutralButton}"
                Opacity="0.85"
                HorizontalOptions="End" VerticalOptions="Start"
                Margin="16" />
    </Grid>
</ContentPage>
