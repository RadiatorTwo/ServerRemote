<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="ServerRemote.App.Components.EmptyStateCard"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="Root">
    <Border Style="{StaticResource Card}">
        <VerticalStackLayout Spacing="10">
            <Label Text="{Binding Title, Source={x:Reference Root}}"
                   Style="{StaticResource CardTitle}" />

            <Border BackgroundColor="{StaticResource SurfaceElevated}"
                    Stroke="{StaticResource Border}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8"
                    Padding="10,5"
                    HorizontalOptions="Start">
                <Label Text="{Binding StatusText, Source={x:Reference Root}}"
                       TextColor="{StaticResource TextSecondary}"
                       FontSize="12"
                       FontAttributes="Bold" />
            </Border>

            <Label Text="{Binding Description, Source={x:Reference Root}}"
                   Style="{StaticResource BodyText}" />
        </VerticalStackLayout>
    </Border>
</ContentView>
