<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="ServerRemote.App.Components.DangerZone"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="Root">
    <Border BackgroundColor="{StaticResource Surface}"
            Stroke="{StaticResource Danger}"
            StrokeThickness="1"
            StrokeShape="RoundRectangle 14"
            Padding="16">
        <VerticalStackLayout Spacing="12">
            <Label Text="Danger Zone"
                   TextColor="{StaticResource Danger}"
                   FontSize="16"
                   FontAttributes="Bold" />
            <Label Text="These actions act directly on the connected machine."
                   Style="{StaticResource MetricCaption}" />

            <FlexLayout Wrap="Wrap" Direction="Row">
                <Button Text="Shut Down"
                        Command="{Binding Monitor.ShutdownCommand, Source={x:Reference Root}}"
                        Style="{StaticResource DangerButton}"
                        MinimumHeightRequest="48"
                        Margin="0,0,8,8" />
                <Button Text="Reboot"
                        Command="{Binding Monitor.RebootCommand, Source={x:Reference Root}}"
                        Style="{StaticResource WarningButton}"
                        MinimumHeightRequest="48"
                        Margin="0,0,0,8" />
            </FlexLayout>
        </VerticalStackLayout>
    </Border>
</ContentView>
