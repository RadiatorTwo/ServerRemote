<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="ServerRemote.App.Components.StorageBar"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:ServerRemote.App.ViewModels"
    x:DataType="vm:DriveItemViewModel">
    <VerticalStackLayout Spacing="6" Padding="0,6">

        <Grid ColumnDefinitions="*,Auto">
            <Label Grid.Column="0"
                   Text="{Binding Name}"
                   TextColor="{StaticResource TextPrimary}"
                   FontSize="15"
                   FontAttributes="Bold"
                   VerticalOptions="Center" />
            <Label Grid.Column="1"
                   Text="{Binding UsedPercent, StringFormat='{0:0} %'}"
                   TextColor="{Binding StatusColor}"
                   FontSize="15"
                   FontAttributes="Bold"
                   VerticalOptions="Center" />
        </Grid>

        <!-- Dicker Belegungsbalken -->
        <Border BackgroundColor="{StaticResource SurfaceElevated}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 5"
                HeightRequest="10">
            <Grid ColumnDefinitions="{Binding UsedFraction, Converter={StaticResource FractionToColumns}}">
                <BoxView Grid.Column="0"
                         BackgroundColor="{Binding StatusColor}"
                         CornerRadius="5" />
            </Grid>
        </Border>

        <Grid ColumnDefinitions="*,Auto">
            <Label Grid.Column="0"
                   Text="{Binding FreeText}"
                   Style="{StaticResource MetricCaption}" />
            <Label Grid.Column="1"
                   Text="{Binding SummaryText}"
                   Style="{StaticResource MetricCaption}" />
        </Grid>

    </VerticalStackLayout>
</ContentView>
