<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="ServerRemote.App.Components.MetricCard"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="Root">
    <Border Style="{StaticResource Card}">
        <VerticalStackLayout Spacing="8">

            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0"
                       Text="{Binding Title, Source={x:Reference Root}}"
                       Style="{StaticResource CardTitle}"
                       VerticalOptions="Center" />

                <!-- Status-Badge -->
                <Border Grid.Column="1"
                        IsVisible="{Binding ShowStatus, Source={x:Reference Root}}"
                        BackgroundColor="{Binding Status, Source={x:Reference Root}, Converter={StaticResource StatusToColor}}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 8"
                        Padding="9,3">
                    <Label Text="{Binding StatusLabel, Source={x:Reference Root}}"
                           Style="{StaticResource StatusBadge}" />
                </Border>
            </Grid>

            <Label Text="{Binding Value, Source={x:Reference Root}}"
                   Style="{StaticResource MetricValue}" />

            <Label Text="{Binding Caption, Source={x:Reference Root}}"
                   Style="{StaticResource MetricCaption}"
                   IsVisible="{Binding Caption, Source={x:Reference Root}, Converter={StaticResource StringNotEmpty}}" />

            <!-- Auslastungsbalken (dick) -->
            <Border IsVisible="{Binding ShowProgress, Source={x:Reference Root}}"
                    BackgroundColor="{StaticResource SurfaceElevated}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 5"
                    HeightRequest="10"
                    Margin="0,4,0,0">
                <Grid ColumnDefinitions="{Binding ProgressColumns, Source={x:Reference Root}}">
                    <BoxView Grid.Column="0"
                             BackgroundColor="{Binding Status, Source={x:Reference Root}, Converter={StaticResource StatusToColor}}"
                             CornerRadius="5" />
                </Grid>
            </Border>

        </VerticalStackLayout>
    </Border>
</ContentView>
