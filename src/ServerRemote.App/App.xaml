<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:ServerRemote.App"
             xmlns:conv="clr-namespace:ServerRemote.App.Converters"
             x:Class="ServerRemote.App.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:PercentToFractionConverter x:Key="PercentToFraction" />
            <conv:BoolToColorConverter x:Key="BoolToColor" />
            <conv:StringNotEmptyConverter x:Key="StringNotEmpty" />
            <conv:StatusToColorConverter x:Key="StatusToColor" />
            <conv:FractionToColumnsConverter x:Key="FractionToColumns" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
