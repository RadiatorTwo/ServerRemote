{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "ServerRemote": {
    "ApiKey": "CHANGE-ME-use-user-secrets-or-env",
    "Network": {
      "HttpsPort": 9443,
      "BindAddress": "0.0.0.0"
    },
    "Certificate": {
      "PfxPath": "",
      "PfxPassword": ""
    },
    "MonitoredServices": [
      {
        "Key": "mssql",
        "DisplayName": "MSSQL Server",
        "WindowsServiceName": "MSSQLSERVER",
        "Controllable": true
      },
      {
        "Key": "postgresql",
        "DisplayName": "PostgreSQL",
        "WindowsServiceName": "postgresql-x64-16",
        "Controllable": true
      }
    ]
  }
}
